# =============================================================================
# Single key (sandbox): one LWA app for Seller Central
# =============================================================================
# If you only have one set of Amazon sandbox credentials, set these three.
# Seller Central reports will use them; Ads will use sample data until you
# add AMAZON_ADS_REFRESH_TOKEN and AMAZON_ADS_PROFILE_ID (same app can be used).

AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
# Refresh token from Seller Central sandbox (authorize your app in Seller Central)
AMAZON_REFRESH_TOKEN=

# =============================================================================
# Or: separate Seller Central (SP-API) credentials
# =============================================================================
# Get credentials: Seller Central → Apps & Services → Develop Apps
# Docs: https://developer-docs.amazon.com/sp-api/docs/connecting-to-the-selling-partner-api

# AMAZON_SELLER_CLIENT_ID=
# AMAZON_SELLER_CLIENT_SECRET=
# AMAZON_SELLER_REFRESH_TOKEN=

# Marketplace (default: US). Examples: ATVPDKIKX0DER (US), A1PA6795UKMFR9 (DE)
AMAZON_SELLER_MARKETPLACE_ID=ATVPDKIKX0DER
# Region: na | eu | fe
AMAZON_SELLER_REGION=na
# Use sandbox endpoints (set to true for sandbox credentials)
# AMAZON_SELLER_SANDBOX=true
# or: AMAZON_SANDBOX=true

# =============================================================================
# Amazon Advertising API (optional – reuse same client id/secret above)
# =============================================================================
# Client ID/Secret: same as AMAZON_CLIENT_ID / AMAZON_CLIENT_SECRET (same LWA app).
# Refresh token: from Advertising API OAuth (NOT Seller Central). See AMAZON_API.md.
# Profile ID: get from GET /api/amazon/ads/profiles (numeric id, NOT marketplace id like ATVPDKIKX0DER).

AMAZON_ADS_CLIENT_ID=
AMAZON_ADS_CLIENT_SECRET=
AMAZON_ADS_REFRESH_TOKEN=
# Numeric profile id from /api/amazon/ads/profiles (e.g. 1234567890), NOT ATVPDKIKX0DER
AMAZON_ADS_PROFILE_ID=
AMAZON_ADS_REGION=na

# =============================================================================
# Optional: app URL (for server-side fetch to own API when needed)
# =============================================================================
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# =============================================================================
# Cube.js configuration
# =============================================================================
CUBE_API_URL=http://localhost:4000/cubejs-api/v1
